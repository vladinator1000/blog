---
import { Image } from "astro:assets"
import PageLayout from "../layouts/PageLayout.astro"
import PageMeta from "../components/PageMeta.astro"
import Carousel from "../components/Carousel.astro"
import { getEnv } from "../lib/cloudflare-env"
import { SITE_TITLE } from "../config"

import img4507 from "../assets/kieran/IMG_4507.webp"
import img4508 from "../assets/kieran/IMG_4508.webp"
import img4510 from "../assets/kieran/IMG_4510.webp"
import img4511 from "../assets/kieran/IMG_4511.webp"
import img4512 from "../assets/kieran/IMG_4512.webp"
import img4522 from "../assets/kieran/IMG_4522.webp"
import img4653 from "../assets/kieran/IMG_4653.webp"
import img4664 from "../assets/kieran/IMG_4664.webp"
import kieranStagQr from "../assets/kieran/kieran-stag-qr.webp"

export const prerender = false

const RSVP_PASSWORD = "wow-magnificent"

interface RSVPData {
  name: string
  attending: "yes" | "no"
  timestamp: string
}

let authenticated = false
let submitted = false
let error = ""

const method = Astro.request.method
const contentType = Astro.request.headers.get("content-type") || ""

if (method === "POST" && contentType.includes("application/x-www-form-urlencoded")) {
  const formData = await Astro.request.formData()
  const action = formData.get("action")

  if (action === "auth") {
    const password = formData.get("password") as string
    if (password === RSVP_PASSWORD) {
      authenticated = true
    } else {
      error = "Wrong password. Try again."
    }
  } else if (action === "submit") {
    const password = formData.get("password") as string
    if (password === RSVP_PASSWORD) {
      authenticated = true
      const name = (formData.get("name") as string || "").trim()
      const attending = (formData.get("attending") as string) as "yes" | "no"

      if (!name) {
        error = "Please enter your name."
      } else {
        const rsvpData: RSVPData = {
          name,
          attending: attending === "yes" ? "yes" : "no",
          timestamp: new Date().toISOString(),
        }

        const env = getEnv()
        const kv = env.RSVP_KV
        const key = `rsvp:${Date.now()}:${name.toLowerCase().replace(/\s+/g, "-")}`
        await kv.put(key, JSON.stringify(rsvpData))
        submitted = true
      }
    } else {
      error = "Wrong password. Try again."
    }
  }
}
---

<PageLayout showHeader={false}>
  <PageMeta title={`Kieran's stag party RSVP | ${SITE_TITLE}`} slot="meta" />
  <section slot="main" class="prose max-w-none">
    <h1 class="mb-6">🍻 Kieran's stag party</h1>

    {authenticated && <Carousel class="mb-6" images={[
      { src: img4507, alt: "Kieran photo 1" },
      { src: img4508, alt: "Kieran photo 2" },
      { src: img4510, alt: "Kieran photo 3" },
      { src: img4511, alt: "Kieran photo 4" },
      { src: img4512, alt: "Kieran photo 5" },
      { src: img4522, alt: "Kieran photo 6" },
      { src: img4653, alt: "Kieran photo 7" },
      { src: img4664, alt: "Kieran photo 8" },
    ]} />}

    {error && (
      <p style="color: #e11d48; font-weight: 600;">{error}</p>
    )}

    {!authenticated && !submitted && (
      <form method="POST" class="mt-6">
        <input type="hidden" name="action" value="auth" />
        <label for="password" class="block mb-2 font-semibold">Password</label>
        <input
          type="password"
          name="password"
          id="password"
          required
          class="block w-full max-w-md px-3 py-2 mb-4  border border-gray-300 dark:border-gray-600 bg-transparent"
          placeholder="Enter the password"
        />
        <button
          type="submit"
          class="px-4 py-2  bg-blue-600 text-white font-semibold hover:bg-blue-700 transition-colors"
        >
          Enter
        </button>
      </form>
    )}

    {authenticated && (
      <div class="px-6  bg-blue-50 dark:bg-blue-900/20 border border-blue-300 dark:border-blue-700">
        <ul>
          <li>18 July 2026, time: TBC</li>
          <li><strong>Pub</strong> location TBC (kitty on the night money-wise)</li>
          <li><strong>Comedy club</strong>,The Stand, 420 Great Western Rd, Glasgow G4 9JA (£23 each)</li>
        </ul>
      </div>
    )}

    {authenticated && !submitted && (
      <form method="POST" class="mt-6 space-y-4">
        <input type="hidden" name="action" value="submit" />
        <input type="hidden" name="password" value={RSVP_PASSWORD} />

        <div>
          <label for="name" class="block mb-2 font-semibold">Your name *</label>
          <input
            type="text"
            name="name"
            id="name"
            required
            class="block w-full max-w-md px-3 py-2 border border-gray-300 dark:border-gray-600 bg-transparent"
            placeholder="John Doe"
          />
        </div>

        <div>
          <label class="block mb-2 font-semibold">Will you be attending? *</label>
          <div class="flex gap-4">
            <label class="flex items-center gap-2">
              <input type="radio" name="attending" value="yes" required class="w-4 h-4" />
              <span>Yes, let's party!</span>
            </label>
            <label class="flex items-center gap-2">
              <input type="radio" name="attending" value="no" class="w-4 h-4" />
              <span>Can't make it.</span>
            </label>
          </div>
        </div>

        <button
          type="submit"
          class="px-4 py-2  bg-green-600 text-white font-semibold hover:bg-green-700 transition-colors"
        >
          Submit
        </button>
      </form>
    )}

    {submitted && (
      <div class="mt-6 p-4  bg-green-100 dark:bg-green-900/30 border border-green-400 dark:border-green-700">
        <h2 style="margin: 0; color: #16a34a;">Submitted!</h2>
        <p>Aww yeah! 🚀 Next steps if you're attending:</p>
        <p><a href="https://chat.whatsapp.com/Gn2Pc12PFu6FvVBQQyet9v?mode=gi_t" target="_blank" rel="noopener noreferrer" style="color: #2563eb; font-weight: 600;">Join WhatsApp Group</a></p>
        <p>Comedy club ticket: <a href="https://monzo.me/vladislavveselinov/23.00?h=B6jWQn&d=Kieran%20comedy%20club&account_type=personal" target="_blank" rel="noopener noreferrer" style="color: #2563eb; font-weight: 600;">Pay £23</a></p>
        <Image src={kieranStagQr} alt="Monzo payment QR code" width={200} height={200} class="my-0 " />
      </div>
    )}
  </section>
</PageLayout>
